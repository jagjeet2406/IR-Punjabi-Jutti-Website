.profile-dropdown {
  z-index: 100;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 8px;
  min-width: 130px;
  position: absolute;
  top: 110%;
  right: 0;
}

.profile-dropdown p {
  cursor: pointer;
  margin: 0;
  padding: 10px 16px;
  font-size: 14px;
}

.modal-overlay {
  z-index: 999;
  background: #00000080;
