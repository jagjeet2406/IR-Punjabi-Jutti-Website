  width: 100%;
  height: 100%;
  display: flex;
  position: fixed;
  top: 0;
  left: 0;
}

.modal-box {
  background: #fff;
  border-radius: 12px;
  min-width: 300px;
  padding: 30px;
  position: relative;
}

.modal-box button {
